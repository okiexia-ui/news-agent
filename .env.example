# Copy this file to .env and fill in real values. .env is gitignored.

# === News fetching (required for scripts/fetch_news.py) ===
# Get a free key at https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key
# HackerNews, Reddit, arXiv, BBC/Bloomberg/CNBC/Economist RSS need no key.

# === Email delivery (required only if you run render_and_send.py without --no-email) ===
# Gmail: use an App Password, not your login password.
# Generate at: Google Account > Security > 2-Step Verification > App passwords
GMAIL_APP_PASSWORD=your-16-char-app-password
FROM_EMAIL=you@gmail.com
TO_EMAILS=recipient1@example.com,recipient2@example.com

# Optional: override if not using Gmail
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# Optional: instead of GMAIL_APP_PASSWORD above, point to a file containing just the password
# GMAIL_APP_PASSWORD_FILE=/path/to/gmail_cred
